# Leads sheet — browser fallback when API hits an old Apps Script deployment (must match server URL below)
VITE_GSHEET_WEBHOOK_URL=https://script.google.com/macros/s/REPLACE_WITH_YOUR_DEPLOYMENT_ID/exec

# Server-side (`.dev.vars` for wrangler pages dev; Cloudflare Pages secrets in production)
# Use the SAME /exec URL for all three (latest deployment with header-map script from scripts/google-apps-script-doPost.gs)
# GSHEET_WEBHOOK_URL=https://script.google.com/macros/s/REPLACE_WITH_YOUR_DEPLOYMENT_ID/exec
# ENQUIRY_GSHEET_WEBHOOK_URL=https://script.google.com/macros/s/REPLACE_WITH_YOUR_DEPLOYMENT_ID/exec
# PAYMENTS_GSHEET_WEBHOOK_URL=https://script.google.com/macros/s/REPLACE_WITH_YOUR_DEPLOYMENT_ID/exec
# Demo registrations (/demo) — separate spreadsheet recommended; tab name: DemoRegistrations
# DEMO_GSHEET_WEBHOOK_URL=https://script.google.com/macros/s/REPLACE_WITH_YOUR_DEPLOYMENT_ID/exec
# DEMO_GSHEET_SPREADSHEET_ID=optional — omit if demos use the same spreadsheet as Leads (add tab DemoRegistrations)
# Demo registration also requires BREVO_API_KEY (confirmation email with Teams link — same as enquiry form)
# Remove any stale GSHEET_WEBHOOK_URL secret in Cloudflare that points at an older deployment.

# Stripe (server-only — use Cloudflare Pages secrets in production; for local full-stack use `.dev.vars` with wrangler pages dev)
#   STRIPE_SECRET_KEY=sk_test_... or sk_live_...
#   STRIPE_PRICE_ID=price_1TVnFvJNVnfKQL0g0IgW81bG
#   STRIPE_VIBE_PRICE_ID=price_1TXaJZJNVnfKQL0gBMQKf0Z3

# Optional: when running Vite on a different port than your deployed API, set the deployed origin (no trailing slash).
# Production on Cloudflare Pages usually leaves this empty so checkout uses same-origin /api/...
# VITE_CHECKOUT_API_URL=https://your-preview.pages.dev

# Enquiry emails use the same Pages origin as checkout: POST /api/send-enquiry-emails
# Brevo secrets are server-only — set them in Cloudflare Pages or in .dev.vars for `wrangler pages dev` (never VITE_*):
#   BREVO_API_KEY
#   BREVO_SENDER_EMAIL   (verified sender in Brevo, e.g. enquiry@nexpertsacademy.com)
#   BREVO_SENDER_NAME    (optional display name)
#   ENQUIRY_LEAD_EMAIL   (optional; default enquiry@nexpertsacademy.com)
#   SITE_PUBLIC_URL      (optional; canonical URL for email CTA buttons, e.g. https://nexpertsai.com)

